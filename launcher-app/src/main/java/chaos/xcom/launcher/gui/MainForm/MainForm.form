                          <terminateEditOnFocusLost class="java.lang.Boolean" value="true"/>
                        </clientProperties>
                      </component>
                    </children>
                  </scrollpane>
                </children>
              </grid>
              <grid id="d536f" layout-manager="GridLayoutManager" row-count="2" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
                <margin top="0" left="0" bottom="0" right="0"/>
                <constraints>
                  <splitpane position="right"/>
                </constraints>
                <properties/>
                <border type="etched" title="Mod information"/>
