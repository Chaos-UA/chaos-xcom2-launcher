                  <component id="a46ea" class="chaos.xcom.launcher.gui.component.XImage" binding="pnlModImage" custom-create="true">
                    <constraints>
                      <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="0" indent="0" use-parent-layout="false">
                        <minimum-size width="80" height="180"/>
                        <preferred-size width="180" height="180"/>
                        <maximum-size width="180" height="180"/>
                      </grid>
                    </constraints>
                    <properties/>
                  </component>
                  <tabbedpane id="981d" binding="tabModInfoPanel">
                    <constraints>
                      <grid row="0" column="1" row-span="2" col-span="1" vsize-policy="3" hsize-policy="7" anchor="0" fill="3" indent="0" use-parent-layout="false">
                        <preferred-size width="200" height="200"/>
                      </grid>
                    </constraints>
                    <properties/>
                    <border type="etched"/>
                    <children>
                      <grid id="c9ff9" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
                        <margin top="0" left="0" bottom="0" right="0"/>
